# Recall app environment template
# Copy to .env.local in this directory.

# --- OpenAI (optional) ---
# Without this, the app falls back to a regex-based classifier and date parser.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Supabase (required for auth + cloud storage) ---
# Get these from https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
APP_BASE_URL=http://localhost:3001

