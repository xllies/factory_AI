{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://darkfactory.dev/schemas/jira-plan.schema.json",
  "title": "JiraPlan",
  "type": "object",
  "required": [
    "source_file",
    "summary",
    "open_questions",
    "epics"
  ],
  "additionalProperties": false,
  "properties": {
    "source_file": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "epics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/epic"
      }
    }
  },
  "definitions": {
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "complexity": {
      "type": "string",
      "enum": [
        "small",
        "medium",
        "large"
      ]
    },
    "subtask": {
      "type": "object",
      "required": [
        "title",
        "description",
        "acceptance_criteria"
      ],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_sections": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "task": {
      "type": "object",
      "required": [
        "title",
        "description",
        "acceptance_criteria",
        "dependencies",
        "priority",
        "complexity",
        "subtasks"
      ],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "priority": {
          "$ref": "#/definitions/priority"
        },
        "complexity": {
          "$ref": "#/definitions/complexity"
        },
        "source_sections": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "subtasks": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/subtask"
          }
        }
      }
    },
    "epic": {
      "type": "object",
      "required": [
        "title",
        "description",
        "source_sections",
        "tasks"
      ],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "source_sections": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/task"
          }
        }
      }
    }
  }
}
